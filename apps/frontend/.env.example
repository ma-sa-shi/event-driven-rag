# .env.localへコピーし、DataStackデプロイ後のCfnOutputの値を設定する(cdk/README.md参照)
# VITE_COGNITO_AUTHORITY: CognitoIssuer出力(User PoolのOIDC discoveryエンドポイント)
# VITE_COGNITO_CLIENT_ID: UserPoolClientId出力
# VITE_COGNITO_DOMAIN: CognitoDomainUrl出力(サインアウトの/logoutリダイレクトに使う)
VITE_COGNITO_AUTHORITY=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
